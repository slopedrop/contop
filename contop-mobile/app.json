{
  "expo": {
    "name": "Contop Mobile",
    "slug": "contop-mobile",
    "version": "0.1.0-alpha.1",
    "scheme": "contop",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "bundleIdentifier": "com.contop.mobile",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Contop needs camera access to scan QR codes for pairing with your host machine.",
        "NSFaceIDUsageDescription": "Contop uses Face ID to securely authenticate you before accessing the app.",
        "NSMicrophoneUsageDescription": "Contop needs microphone access to capture voice commands for your AI assistant",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.contop.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundColor": "#000000"
      },
      "softwareKeyboardLayoutMode": "adjustNothing",
      "permissions": [
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "splash": {
      "image": "./assets/images/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "updates": {
      "url": "https://u.expo.dev/5af67171-d956-494f-b8c1-6a79e2f2c899",
      "enabled": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      "expo-font",
      "expo-audio",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Contop uses your location to show where your device is connecting from."
        }
      ],
      "./plugins/withDataPersistence",
      "./plugins/withSplashIconPadding",
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "5af67171-d956-494f-b8c1-6a79e2f2c899"
      }
    },
    "owner": "swaroop_meher"
  }
}
